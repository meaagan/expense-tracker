<%= form_with model: @expense do |f| %>
  <% if @expense.errors.any? %>
    <div role="alert">
      <h2><%= pluralize(@expense.errors.count, "error") %> prohibited this expense from being saved:</h2>
      <ul>
        <% @expense.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name %>
    <%= f.text_field :name %>
  </div>

  <div>
    <%= f.label :category %>
    <%= f.select :category, Expense::CATEGORIES.keys.map { |k| [k.to_s.titleize, k.to_s] }, include_blank: "Select a category" %>
  </div>

  <div>
    <%= f.label :amount %>
    <%= f.number_field :amount, step: 0.01, min: 0 %>
  </div>

  <div>
    <%= f.label :date %>
    <%= f.date_field :date %>
  </div>

  <div>
    <%= f.submit %>
  </div>
<% end %>
