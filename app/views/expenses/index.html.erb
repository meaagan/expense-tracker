<h1>Expenses</h1>

<p><%= link_to "New expense", new_expense_path %></p>

<% if @expenses.any? %>
  <table>
    <thead>
      <tr>
        <th>Name</th>
        <th>Category</th>
        <th>Amount</th>
        <th>Date</th>
        <th colspan="3"></th>
      </tr>
    </thead>
    <tbody>
      <% @expenses.each do |expense| %>
        <tr>
          <td><%= expense.name %></td>
          <td><%= expense.category.to_s.titleize %></td>
          <td><%= number_to_currency(expense.amount) %></td>
          <td><%= expense.date&.strftime("%Y-%m-%d") %></td>
          <td><%= link_to "Show", expense_path(expense) %></td>
          <td><%= link_to "Edit", edit_expense_path(expense) %></td>
          <td>
            <%= link_to "Delete", expense_path(expense), data: { turbo_method: :delete, turbo_confirm: "Delete this expense?" } %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p>No expenses yet. <%= link_to "Add one", new_expense_path %>.</p>
<% end %>
